@inherits LayoutComponentBase
@implements IDisposable
@inject kursovayaWeb.Models.AuthState AuthState
@inject NavigationManager Navigation

<div class="app-container">

    @if (AuthState.IsAuthenticated)
    {
        
        <header class="app-header">
            <span class="app-logo">[ЛОГО] Система производства СЗР</span>
            <span class="app-section">Раздел: @CurrentSection</span>
            <span class="app-status">● Online</span>
            <span class="app-user">@AuthState.FullName</span>
            <button class="logout-btn" @onclick="Logout">Выход</button>
        </header>

        <div class="app-body">
            
            <nav class="app-menu">
                <NavLink href="active-batches" Match="NavLinkMatch.All">Активные партии</NavLink>
                <NavLink href="batch-program">Программа партии</NavLink>
                <NavLink href="extruder-live">Экструдер LIVE</NavLink>
                <NavLink href="batch-log">Журнал партии</NavLink>
                <NavLink href="report-problem">Сообщить о проблеме</NavLink>
            </nav>

            
            <main class="app-content">
                @Body
            </main>
        </div>
    }
    else
    {
        
        <main class="login-content">
            @Body
        </main>
    }

</div>

@code {
    private string CurrentSection = "";

    protected override void OnInitialized()
    {
        
        Navigation.LocationChanged += OnLocationChanged;
        UpdateSection();
    }
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        
        InvokeAsync(() =>
        {
            UpdateSection();
        });
    }

    private void UpdateSection()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("/active-batches")) CurrentSection = "Активные партии";
        else if (uri.Contains("/batch-program")) CurrentSection = "Программа партии";
        else if (uri.Contains("/extruder-live")) CurrentSection = "Экструдер LIVE";
        else if (uri.Contains("/batch-log")) CurrentSection = "Журнал партии";
        else CurrentSection = "";

        StateHasChanged();
    }

    private void Logout()
    {
        AuthState.Logout();
        Navigation.NavigateTo("/");
    }
    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}